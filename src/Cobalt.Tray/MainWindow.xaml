<Window x:Class="Cobalt.Tray.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:local="clr-namespace:Cobalt.Tray"
        WindowState="Minimized" WindowStyle="None"
        ShowInTaskbar="False" ShowActivated="False" AllowsTransparency="True">
    <tb:TaskbarIcon x:Name="Tray">
        <tb:TaskbarIcon.TrayPopup>
            <local:TrayView Width="450" Height="450"/>
        </tb:TaskbarIcon.TrayPopup>
    </tb:TaskbarIcon>
</Window>